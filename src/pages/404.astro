---
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---

<Layout title="(404) Uh Oh!" description="Are you lost?">
  <div>
    <p id="emoji">
      <h1>404 - Page Not Found</h1>
      <a href="/">$cd home</a>
    </p>
  </div>
</Layout>

<script>
  const emojiArray = [
    "\\(o_o)/",
    "(o^^)o",
    "(˚Δ˚)b",
    "(^-^*)",
    "(^_^)b",
    "(╯‵□′)╯",
    "(='X'=)",
    "(>_<)",
    "\\(°ˊДˋ°)/",
    "ㄟ(▔▽▔)ㄏ",
  ];

  const emoji = document.querySelector("#emoji");
  if (emoji)
    emoji.innerHTML = emojiArray[Math.floor(Math.random() * emojiArray.length)];
</script>

<style lang="scss">
  div {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
  }
  #emoji {
    font-size: clamp(40px, 5vw, 70px);
    font-weight: 500;
    color: var(--accent);
  }
  h1 {
    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--lg);

    &:hover {
      color: var(--color);
      text-decoration: underline;
    }
  }
</style>
