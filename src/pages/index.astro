---
import Layout from "../layouts/Layout.astro";

const contact = [
    {
        label: "Email",
        link: "mailto:example@mail.com",
        shortcut: "@viann",
    },
    {
        label: "LinkedIn",
        link: "https://linkedin.com/in/username",
        shortcut: "@viannle",
    },
    {
        label: "Github",
        link: "https://github.com/enna-ai",
        shortcut: "@enna-ai",
    }
];
---

<Layout title="Vi's Site" description="My portfolio website">
  <header>
    <img
      src="https://i.imgur.com/2DEVDhK.png"
      width={250}
      height={250}
      alt="Avatar"
    />
  </header>

  <section>
    <div>
      <span>
        <h1>Hi, I'm <span>Vi</span>!</h1>
        <span>(she/her)</span>
      </span>

      <h2>software developer, graphic designer</h2>
    </div>

    <p>
      I'm a self-taught full stack software developer with a focus in building
      front-end web apps, command-line tools and occasionally creating graphic
      design assets.
    </p>

    <div>
      <p>You can find me all over the interwebs:</p>
      <iframe
        title="Discord user embed"
        width="340"
        height="72"
        frameborder="0"
        sandbox="allow-scripts"
        src="https://widgets.vendicated.dev/user?id=454115882235330561&theme=dark&banner=false&full-banner=false&rounded-corners=true&discord-icon=true&badges=false&guess-nitro=false&background-color=%23c2739d1e&foreground-color=%23C2739D"
      ></iframe>

      <ul>
        {contact.map((item) => (
            <li>
                {item.label} — <a href={item.link}>{item.shortcut}</a>
            </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
