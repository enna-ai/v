---
import ProjectCard from "./ProjectCard.astro"

const repos = [
    "https://api.github.com/repos/enna-ai/axle-ai",
    "https://api.github.com/repos/enna-ai/spotify-clone",
    "https://api.github.com/repos/enna-ai/pic-ai",
    "https://api.github.com/repos/enna-ai/task-flow",
    "https://api.github.com/repos/enna-ai/aniview",
];
---

<div>
    {repos.map(repo => <ProjectCard repo={repo} />)}
</div>

<style>
    div {
        --cols: 3;
        display: grid;
        grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
        gap: 0.75em;
    }

    @media screen and (max-width: 1400px) {
        div {
            --cols: 2;
        }
    }

    @media screen and (max-width: 1000px) {
        div {
            --cols: 1;
        }
    }
</style>